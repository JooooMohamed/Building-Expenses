PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/building-expenses
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Payment Gateway (Nestpay)
NESTPAY_CLIENT_ID=
NESTPAY_STORE_KEY=
NESTPAY_STORE_TYPE=3d_pay
NESTPAY_GATEWAY_URL=https://entegrasyon.asseco-see.com.tr/fim/est3Dgate

# API Base URL (for payment callbacks)
API_BASE_URL=http://localhost:3000/api/v1
